<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>퀴즈 마스터</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root{--bg:#0d0f14;--sur:#161921;--sur2:#1e2230;--bdr:#2a2f3d;--txt:#e8eaf0;--mut:#6b7280;--ac:#4f8ef7;--ac2:#7c5cf6;--ok:#22c55e;--err:#ef4444;--r:14px}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Noto Sans KR',sans-serif;background:var(--bg);color:var(--txt);min-height:100vh;display:flex;flex-direction:column;align-items:center}
.btn{padding:10px 22px;border:none;border-radius:8px;cursor:pointer;font-family:'Noto Sans KR',sans-serif;font-size:14px;font-weight:500;transition:all .2s}
.btn-p{background:linear-gradient(135deg,var(--ac),var(--ac2));color:#fff}.btn-p:hover{filter:brightness(1.12);transform:translateY(-1px)}
.btn-s{background:var(--sur2);color:var(--txt);border:1px solid var(--bdr)}.btn-s:hover{background:var(--bdr)}
.btn-d{background:#7f1d1d;color:#fca5a5;border:none}.btn-d:hover{background:#991b1b}
#app{width:100%;max-width:780px;padding:30px 20px 80px}
.app-title{font-size:22px;font-weight:900;letter-spacing:-.5px;background:linear-gradient(120deg,var(--ac),var(--ac2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.app-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:36px}
.screen{display:none;animation:fi .3s ease}.screen.active{display:block}
@keyframes fi{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
/* 홈 */
.home-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:30px}
.stat-card{background:var(--sur);border:1px solid var(--bdr);border-radius:var(--r);padding:18px;text-align:center}
.stat-card .num{font-size:32px;font-weight:900;font-family:'Space Mono',monospace}
.stat-card .lbl{font-size:12px;color:var(--mut);margin-top:4px}
.ok-num{color:var(--ok)}.err-num{color:var(--err)}.pend-num{color:var(--mut)}
.sec{font-size:13px;font-weight:700;color:var(--mut);text-transform:uppercase;letter-spacing:1px;margin:28px 0 12px}
.cat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px}
.cat-card{background:var(--sur);border:1px solid var(--bdr);border-radius:var(--r);padding:18px 16px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden}
.cat-card::before{content:'';position:absolute;inset:0;opacity:0;transition:opacity .2s;background:linear-gradient(135deg,rgba(79,142,247,.15),rgba(124,92,246,.15))}
.cat-card:hover::before{opacity:1}.cat-card:hover{border-color:var(--ac);transform:translateY(-2px)}
.cat-card.all{border-color:var(--ac2);background:linear-gradient(135deg,rgba(79,142,247,.08),rgba(124,92,246,.08))}
.cat-card .cn{font-weight:700;font-size:15px;margin-bottom:6px}.cat-card .cc{font-size:12px;color:var(--mut)}
.dots{display:flex;gap:4px;margin-top:10px;flex-wrap:wrap}
.dot{width:8px;height:8px;border-radius:50%}.dot.c{background:var(--ok)}.dot.w{background:var(--err)}.dot.p{background:var(--mut)}
/* 관리 */
.toolbar{display:flex;gap:10px;margin-bottom:18px;flex-wrap:wrap;align-items:center}
.toolbar input{flex:1;min-width:140px;padding:9px 14px;background:var(--sur);border:1px solid var(--bdr);border-radius:8px;color:var(--txt);font-size:14px;font-family:'Noto Sans KR',sans-serif}
.toolbar input:focus{outline:none;border-color:var(--ac)}
.q-item{background:var(--sur);border:1px solid var(--bdr);border-radius:var(--r);padding:16px;margin-bottom:10px;display:flex;align-items:flex-start;gap:14px}
.q-icon{font-size:22px;flex-shrink:0;margin-top:2px}.q-body{flex:1;min-width:0}
.q-q{font-weight:500;margin-bottom:4px;word-break:break-word}.q-a{font-size:13px;color:var(--mut)}
.q-cat{font-size:11px;background:var(--sur2);border-radius:4px;padding:2px 7px;display:inline-block;margin-top:5px;color:var(--mut)}
.q-img{width:60px;height:60px;object-fit:cover;border-radius:8px;border:1px solid var(--bdr);flex-shrink:0;cursor:pointer}
.q-acts{display:flex;gap:6px;flex-shrink:0}
/* 모달 */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.76);z-index:100;align-items:center;justify-content:center;padding:20px}
.overlay.open{display:flex}
.modal{background:var(--sur);border:1px solid var(--bdr);border-radius:18px;padding:28px;width:100%;max-width:500px;max-height:90vh;overflow-y:auto}
.modal h3{font-size:18px;font-weight:700;margin-bottom:20px}
.fg{margin-bottom:16px}.fl{font-size:13px;color:var(--mut);margin-bottom:6px;display:block}
.fi{width:100%;padding:10px 14px;background:var(--bg);border:1px solid var(--bdr);border-radius:8px;color:var(--txt);font-size:14px;font-family:'Noto Sans KR',sans-serif;transition:border-color .2s}
.fi:focus{outline:none;border-color:var(--ac)}textarea.fi{resize:vertical;min-height:80px}
.m-acts{display:flex;gap:10px;justify-content:flex-end;margin-top:20px}
.chips{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px;min-height:4px}
.chip{padding:4px 12px;border-radius:99px;font-size:12px;background:var(--sur2);border:1px solid var(--bdr);color:var(--mut);cursor:pointer;transition:all .15s}
.chip:hover{border-color:var(--ac);color:var(--ac)}
/* 이미지 */
.img-zone{width:100%;padding:22px 16px;background:var(--bg);border:2px dashed var(--bdr);border-radius:10px;cursor:pointer;text-align:center;font-size:13px;color:var(--mut);transition:all .2s;position:relative}
.img-zone:hover,.img-zone.over{border-color:var(--ac);color:var(--ac);background:rgba(79,142,247,.05)}
.img-zone .zi{font-size:28px;margin-bottom:6px}.img-zone .zt{font-weight:600;margin-bottom:4px}.img-zone .zs{font-size:11px;opacity:.65}
.img-zone input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.prev-wrap{position:relative;display:inline-block;margin-top:8px}
.prev-img{max-height:150px;max-width:100%;border-radius:8px;border:1px solid var(--bdr);display:block}
.prev-rm{position:absolute;top:-9px;right:-9px;background:var(--sur2);border:1px solid var(--bdr);color:#f87171;border-radius:50%;width:24px;height:24px;cursor:pointer;font-size:13px;line-height:24px;text-align:center;z-index:2}
/* 퀴즈 */
.ord-row{display:flex;gap:8px;margin-bottom:22px}
.ord-btn{padding:7px 16px;border-radius:99px;font-size:13px;border:1px solid var(--bdr);background:var(--sur);color:var(--mut);cursor:pointer;transition:all .2s}
.ord-btn.active{background:linear-gradient(135deg,var(--ac),var(--ac2));border-color:transparent;color:#fff}
.qhdr{display:flex;align-items:center;gap:14px;margin-bottom:28px}.qprog{flex:1}
.qprog-lbl{font-size:12px;color:var(--mut);margin-bottom:6px;display:flex;justify-content:space-between}
.pbar{height:4px;background:var(--sur2);border-radius:99px;overflow:hidden}
.pfill{height:100%;background:linear-gradient(90deg,var(--ac),var(--ac2));border-radius:99px;transition:width .4s}
.qcard{background:var(--sur);border:1px solid var(--bdr);border-radius:20px;padding:32px;margin-bottom:22px;position:relative;overflow:hidden}
.qcard::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--ac),var(--ac2))}
.qnum{font-size:12px;color:var(--mut);margin-bottom:12px;font-family:'Space Mono',monospace}
.qtxt{font-size:20px;font-weight:700;line-height:1.5;margin-bottom:18px}
.qimg{max-width:100%;max-height:240px;border-radius:12px;margin-bottom:18px;border:1px solid var(--bdr);display:block;cursor:pointer}
.ans-row{display:flex;gap:10px;align-items:flex-end}
.ans-in{flex:1;padding:13px 18px;background:var(--bg);border:2px solid var(--bdr);border-radius:10px;color:var(--txt);font-size:16px;font-family:'Noto Sans KR',sans-serif;transition:border-color .2s}
.ans-in:focus{outline:none;border-color:var(--ac)}.ans-in:disabled{opacity:.5}
.sub-btn{padding:13px 24px;background:linear-gradient(135deg,var(--ac),var(--ac2));border:none;border-radius:10px;color:#fff;font-size:15px;font-weight:700;cursor:pointer;transition:all .2s;white-space:nowrap;font-family:'Noto Sans KR',sans-serif}
.sub-btn:hover{filter:brightness(1.15)}.sub-btn:disabled{opacity:.4;cursor:not-allowed}
/* 피드백 */
.fb-ov{display:none;position:fixed;inset:0;z-index:500;align-items:center;justify-content:center;background:rgba(0,0,0,.65);backdrop-filter:blur(4px)}
.fb-ov.show{display:flex}
.fb-box{text-align:center;padding:44px 52px;border-radius:24px;border:2px solid;animation:pop .3s cubic-bezier(.34,1.56,.64,1);max-width:360px;width:90%}
@keyframes pop{from{transform:scale(.7);opacity:0}to{transform:scale(1);opacity:1}}
.fb-box.ok{background:rgba(6,30,15,.97);border-color:var(--ok)}.fb-box.er{background:rgba(30,6,6,.97);border-color:var(--err)}
.fb-icon{font-size:64px;margin-bottom:12px}.fb-lbl{font-size:28px;font-weight:900;margin-bottom:8px}
.fb-box.ok .fb-lbl{color:var(--ok)}.fb-box.er .fb-lbl{color:var(--err)}
.fb-ans{font-size:15px;color:var(--mut);margin-top:10px}.fb-ans strong{color:var(--txt);font-size:17px}
.fb-timer{width:44px;height:44px;margin:18px auto 0;position:relative}
.fb-timer svg{transform:rotate(-90deg)}.fb-timer circle{fill:none;stroke-width:3;stroke-linecap:round;stroke-dasharray:120}
.bg-c{stroke:rgba(255,255,255,.1)}.fb-box.ok .fg-c{stroke:var(--ok)}.fb-box.er .fg-c{stroke:var(--err)}
.fb-tnum{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:14px;font-family:'Space Mono',monospace;font-weight:700}
/* 점 네비 */
.dot-nav{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:22px}
.dn{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-family:'Space Mono',monospace;border:2px solid;cursor:pointer;transition:transform .15s;font-weight:700}
.dn:hover{transform:scale(1.15)}.dn.pending{border-color:var(--mut);color:var(--mut);background:transparent}
.dn.correct{border-color:var(--ok);color:var(--ok);background:rgba(34,197,94,.1)}.dn.wrong{border-color:var(--err);color:var(--err);background:rgba(239,68,68,.1)}
.dn.cur{box-shadow:0 0 0 3px rgba(79,142,247,.5)}
/* 결과 */
.result{text-align:center;padding:40px 20px}.result .big{font-size:72px;margin-bottom:12px}
.result .rtit{font-size:26px;font-weight:900;margin-bottom:8px}.result .rsub{color:var(--mut);margin-bottom:30px}
.rstats{display:flex;justify-content:center;gap:24px;margin-bottom:36px}
.rstat .n{font-size:36px;font-weight:900;font-family:'Space Mono',monospace}.rstat .l{font-size:12px;color:var(--mut);margin-top:2px}
/* 이미지 확대 */
.img-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:600;align-items:center;justify-content:center;padding:20px;cursor:pointer}
.img-ov.open{display:flex}.img-ov img{max-width:100%;max-height:85vh;border-radius:12px;pointer-events:none}
.img-ov-x{position:fixed;top:16px;right:20px;font-size:26px;color:#fff;cursor:pointer}
/* 하단 탭 */
.bnav{position:fixed;bottom:0;left:0;right:0;background:rgba(13,15,20,.93);backdrop-filter:blur(12px);border-top:1px solid var(--bdr);display:flex;justify-content:center}
.bnav-in{width:100%;max-width:780px;display:flex}
.ntab{flex:1;padding:12px 0 10px;background:none;border:none;color:var(--mut);cursor:pointer;font-family:'Noto Sans KR',sans-serif;font-size:11px;display:flex;flex-direction:column;align-items:center;gap:4px;transition:color .2s}
.ntab .ni{font-size:20px}.ntab.active{color:var(--ac)}
.empty{text-align:center;padding:60px 20px;color:var(--mut)}.empty .ei{font-size:48px;margin-bottom:12px}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--bdr);border-radius:99px}

/* ── 그리기 모달 ── */
.draw-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:400;align-items:center;justify-content:center;padding:12px}
.draw-ov.open{display:flex}
.draw-modal{background:var(--sur);border:1px solid var(--bdr);border-radius:18px;display:flex;flex-direction:column;overflow:hidden;width:min(720px,100%);max-height:calc(100vh - 24px)}
.dtb{display:flex;align-items:center;gap:5px;padding:9px 11px;background:var(--sur2);border-bottom:1px solid var(--bdr);flex-wrap:wrap}
.tg{display:flex;align-items:center;gap:4px}
.tsep{width:1px;height:24px;background:var(--bdr);margin:0 2px;flex-shrink:0}
.tb{width:32px;height:32px;border-radius:7px;border:1px solid var(--bdr);background:var(--sur);color:var(--txt);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0;padding:0}
.tb:hover{background:var(--bdr)}.tb.on{background:var(--ac);border-color:var(--ac);color:#fff}.tb.era-on{background:#f97316;border-color:#f97316;color:#fff}
.tb:disabled{opacity:.3;cursor:not-allowed}
.tlbl{font-size:11px;color:var(--mut);font-family:'Space Mono',monospace;min-width:20px;text-align:center}
input[type=range].tr{-webkit-appearance:none;width:72px;height:4px;background:var(--bdr);border-radius:99px;outline:none;cursor:pointer}
input[type=range].tr::-webkit-slider-thumb{-webkit-appearance:none;width:13px;height:13px;border-radius:50%;background:var(--ac);cursor:pointer}
.sw{width:22px;height:22px;border-radius:50%;border:2px solid transparent;cursor:pointer;transition:transform .15s;flex-shrink:0}
.sw:hover{transform:scale(1.2)}.sw.sel{border-color:#fff;transform:scale(1.2)}
input[type=color].tc{width:22px;height:22px;border:none;padding:0;border-radius:50%;cursor:pointer;background:none}
.cwrap{position:relative;display:flex;align-items:center;justify-content:center;flex:1;overflow:hidden;background:#1a1c24;padding:8px;min-height:180px;touch-action:none;user-select:none}
#draw-canvas{background:#fff;border-radius:3px;display:block;max-width:100%;max-height:100%;box-shadow:0 2px 16px rgba(0,0,0,.4);touch-action:none}
#lasso-cv{position:absolute;top:0;left:0;pointer-events:none}
/* 올가미 패널 */
#lasso-panel{display:none;position:absolute;bottom:8px;left:50%;transform:translateX(-50%);
  background:var(--sur2);border:1px solid var(--bdr);border-radius:11px;padding:8px 12px;
  align-items:center;gap:8px;flex-wrap:wrap;box-shadow:0 4px 20px rgba(0,0,0,.6);z-index:20;white-space:nowrap}
#lasso-panel.show{display:flex}
.lp-lbl{font-size:11px;color:var(--mut)}
.lp-sw{width:18px;height:18px;border-radius:50%;cursor:pointer;border:2px solid transparent;flex-shrink:0;transition:transform .15s}
.lp-sw:hover{transform:scale(1.2)}.lp-sw.sel{border-color:#fff}
input[type=color].lp-col{width:18px;height:18px;border:none;padding:0;border-radius:50%;cursor:pointer;background:none}
.lp-hint{font-size:10px;color:var(--mut);opacity:.8}
.dfoot{display:flex;gap:8px;padding:9px 11px;border-top:1px solid var(--bdr);justify-content:space-between;align-items:center}
.prev-edit{position:absolute;top:-9px;left:-9px;background:var(--sur2);border:1px solid var(--bdr);color:var(--ac);border-radius:50%;width:24px;height:24px;cursor:pointer;font-size:13px;line-height:24px;text-align:center;z-index:2}
.crop-handle{position:absolute;width:12px;height:12px;background:#fff;border:2px solid #4f8ef7;border-radius:2px;z-index:10}
.spen-ind{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--mut)}
.spen-dot{width:8px;height:8px;border-radius:50%;background:var(--mut)}.spen-dot.era{background:#f97316}
</style>
</head>
<body>
<div id="app">
  <div class="app-header"><span class="app-title">퀴즈 마스터</span></div>

  <div id="screen-home" class="screen active">
    <div class="home-stats">
      <div class="stat-card"><div class="num ok-num" id="s-ok">0</div><div class="lbl">✅ 정답</div></div>
      <div class="stat-card"><div class="num err-num" id="s-err">0</div><div class="lbl">❌ 오답</div></div>
      <div class="stat-card"><div class="num pend-num" id="s-pend">0</div><div class="lbl">❓ 미풀이</div></div>
    </div>
    <div class="sec">카테고리 선택</div>
    <div class="cat-grid" id="cat-grid"></div>
    <div id="home-empty" class="empty" style="display:none"><div class="ei">📚</div><div>아직 문제가 없어요.<br>문제 관리 탭에서 추가해 보세요!</div></div>
  </div>

  <div id="screen-manage" class="screen">
    <div class="toolbar">
      <input type="text" id="filter-in" placeholder="🔍 검색…" oninput="renderList()">
      <button class="btn btn-p" onclick="openAdd()">+ 추가</button>
    </div>
    <div id="q-list"></div>
    <div id="manage-empty" class="empty" style="display:none"><div class="ei">✏️</div><div>문제를 추가해 보세요!</div></div>
  </div>

  <div id="screen-quiz" class="screen">
    <div class="ord-row">
      <button class="ord-btn active" id="ord-seq" onclick="setOrder('seq')">📋 순서대로</button>
      <button class="ord-btn" id="ord-rnd" onclick="setOrder('rnd')">🔀 무작위</button>
    </div>
    <div class="qhdr">
      <button class="btn btn-s" style="padding:8px 14px;font-size:13px" onclick="goHome()">← 홈</button>
      <div class="qprog">
        <div class="qprog-lbl"><span id="prog-lbl">0/0</span><span id="prog-cat"></span></div>
        <div class="pbar"><div class="pfill" id="pfill" style="width:0%"></div></div>
      </div>
    </div>
    <div class="dot-nav" id="dot-nav"></div>
    <div id="quiz-area"></div>
  </div>
</div>

<div class="bnav"><div class="bnav-in">
  <button class="ntab active" id="tab-home" onclick="showScreen('home')"><span class="ni">🏠</span>홈</button>
  <button class="ntab" id="tab-manage" onclick="showScreen('manage')"><span class="ni">📝</span>문제 관리</button>
  <button class="ntab" id="tab-quiz" style="pointer-events:none;opacity:.4"><span class="ni">🎯</span>풀기</button>
</div></div>

<!-- 추가/수정 모달 -->
<div class="overlay" id="modal">
  <div class="modal">
    <h3 id="modal-title">문제 추가</h3>
    <div class="fg">
      <label class="fl">카테고리 *</label>
      <div class="chips" id="chips"></div>
      <input class="fi" id="f-cat" placeholder="카테고리 직접 입력 또는 위에서 선택" autocomplete="off">
    </div>
    <div class="fg"><label class="fl">문제 *</label><textarea class="fi" id="f-q" placeholder="문제를 입력하세요"></textarea></div>
    <div class="fg"><label class="fl">정답 *</label><input class="fi" id="f-a" placeholder="정답을 입력하세요"></div>
    <div class="fg">
      <label class="fl">이미지 첨부 (선택)</label>
      <div id="img-input-area">
        <div class="img-zone" id="img-zone">
          <input type="file" id="f-img" accept="image/*">
          <div class="zi">🖼️</div><div class="zt">클릭 · 드래그 앤 드롭 · Ctrl+V</div><div class="zs">JPG · PNG · GIF · WEBP</div>
        </div>
        <button class="btn btn-s" type="button" id="btn-draw" style="width:100%;margin-top:8px;padding:10px;font-size:13px">✏️ 직접 그리기</button>
      </div>
      <div class="prev-wrap" id="prev-wrap" style="display:none">
        <img id="prev-img" class="prev-img" src="" alt="">
        <button class="prev-rm" type="button" id="prev-rm" title="이미지 제거">✕</button>
        <button class="prev-edit" type="button" id="prev-edit" title="편집">✏️</button>
      </div>
    </div>
    <div class="m-acts">
      <button class="btn btn-s" type="button" id="btn-cancel">취소</button>
      <button class="btn btn-p" type="button" id="btn-save">저장</button>
    </div>
  </div>
</div>

<!-- 그리기 모달 -->
<div class="draw-ov" id="draw-ov">
  <div class="draw-modal">
    <!-- 툴바 -->
    <div class="dtb">
      <div class="tg">
        <button class="tb on" id="tool-pen" title="펜">
