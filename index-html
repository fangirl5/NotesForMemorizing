<script>
/* ══════ 데이터 ══════ */
let qs=[];try{qs=JSON.parse(localStorage.getItem('qm3')||'[]');}catch(e){}
let editId=null,imgData=null,imgIsDrawn=false,queue=[],qIdx=0,qCat='__ALL__',qOrd='seq',rafId=null;
const save=()=>{try{localStorage.setItem('qm3',JSON.stringify(qs));}catch(e){}};
const uid=()=>Date.now().toString(36)+Math.random().toString(36).slice(2,6);
const norm=s=>String(s).trim().toLowerCase().replace(/\s+/g,' ');

/* ══════ 화면 ══════ */
function showScreen(n){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById('screen-'+n).classList.add('active');
  document.querySelectorAll('.ntab').forEach(t=>t.classList.remove('active'));
  const t=document.getElementById('tab-'+n);if(t)t.classList.add('active');
  if(n==='home')renderHome();if(n==='manage')renderList();
}

/* ══════ 홈 ══════ */
function renderHome(){
  document.getElementById('s-ok').textContent=qs.filter(q=>q.st==='correct').length;
  document.getElementById('s-err').textContent=qs.filter(q=>q.st==='wrong').length;
  document.getElementById('s-pend').textContent=qs.filter(q=>q.st==='pending').length;
  const grid=document.getElementById('cat-grid'),empty=document.getElementById('home-empty');
  grid.innerHTML='';
  if(!qs.length){empty.style.display='';return;}empty.style.display='none';
  const cats=[...new Set(qs.map(q=>q.cat))];
  mkCard(grid,'__ALL__','전체 📚',qs,true);
  if(cats.length){addSec(grid,'카테고리별');cats.forEach(c=>mkCard(grid,c,c,qs.filter(q=>q.cat===c),false));}
  const grps=[['correct','✅ 정답'],['wrong','❌ 오답'],['pending','❓ 미풀이']];
  if(grps.some(([s])=>qs.some(q=>q.st===s))){
    addSec(grid,'상태별');
    grps.forEach(([st,lbl])=>{const p=qs.filter(q=>q.st===st);if(p.length)mkCard(grid,'__st__'+st,lbl,p,false);});
  }
}
function addSec(p,t){const d=document.createElement('div');d.className='sec';d.style.cssText='grid-column:1/-1;margin-top:4px;margin-bottom:0';d.textContent=t;p.appendChild(d);}
function mkCard(p,key,lbl,pool,isAll){
  const c=pool.filter(q=>q.st==='correct').length,w=pool.filter(q=>q.st==='wrong').length,pn=pool.filter(q=>q.st==='pending').length;
  const card=document.createElement('div');card.className='cat-card'+(isAll?' all':'');
  const cn=document.createElement('div');cn.className='cn';cn.textContent=lbl;
  const cc=document.createElement('div');cc.className='cc';cc.textContent=pool.length+'문제';
  const do_=document.createElement('div');do_.className='dots';
  for(let i=0;i<Math.min(c,8);i++){const d=document.createElement('span');d.className='dot c';do_.appendChild(d);}
  for(let i=0;i<Math.min(w,8);i++){const d=document.createElement('span');d.className='dot w';do_.appendChild(d);}
  for(let i=0;i<Math.min(pn,8);i++){const d=document.createElement('span');d.className='dot p';do_.appendChild(d);}
  card.append(cn,cc,do_);

  // 짧게 클릭 → 퀴즈 시작, 길게 누르기 → 카테고리 메뉴 (일반 카테고리만)
  let pressTimer=null;
  let longPressed=false;
  const startPress=()=>{
    longPressed=false;
    if(!isAll&&!key.startsWith('__st__')){
      pressTimer=setTimeout(()=>{longPressed=true;openCatMenu(key);},500);
    }
  };
  const endPress=(e)=>{
    clearTimeout(pressTimer);
    if(longPressed){e.preventDefault();return;}
    startQuiz(key);
  };
  const cancelPress=()=>clearTimeout(pressTimer);

  card.addEventListener('mousedown',startPress);
  card.addEventListener('mouseup',endPress);
  card.addEventListener('mouseleave',cancelPress);
  card.addEventListener('touchstart',startPress,{passive:true});
  card.addEventListener('touchend',endPress);
  card.addEventListener('touchcancel',cancelPress);

  p.appendChild(card);
}

/* ══════ 관리 ══════ */
function renderList(){
  const f=(document.getElementById('filter-in')?.value||'').toLowerCase();
  const list=document.getElementById('q-list'),empty=document.getElementById('manage-empty');
  let pool=qs;if(f)pool=pool.filter(q=>q.q.toLowerCase().includes(f)||q.a.toLowerCase().includes(f)||q.cat.toLowerCase().includes(f));
  list.innerHTML='';if(!pool.length){empty.style.display='';return;}empty.style.display='none';
  const ico={correct:'🔵',wrong:'🔴',pending:'⬜'};
  pool.forEach(q=>{
    const row=document.createElement('div');row.className='q-item';
    const ic=document.createElement('div');ic.className='q-icon';ic.textContent=ico[q.st]||'⬜';
    const bd=document.createElement('div');bd.className='q-body';
    const qe=document.createElement('div');qe.className='q-q';qe.textContent=q.q;
    const ae=document.createElement('div');ae.className='q-a';ae.textContent='정답: '+q.a;
    const ce=document.createElement('span');ce.className='q-cat';ce.textContent=q.cat;
    bd.append(qe,ae,ce);
    const acts=document.createElement('div');acts.className='q-acts';
    const eb=document.createElement('button');eb.className='btn btn-s';eb.style.cssText='padding:6px 12px;font-size:12px';eb.textContent='편집';
    const db=document.createElement('button');db.className='btn btn-d';db.style.cssText='padding:6px 12px;font-size:12px';db.textContent='삭제';
    eb.addEventListener('click',()=>openEdit(q.id));db.addEventListener('click',()=>delQ(q.id));
    acts.append(eb,db);row.append(ic,bd);
    if(q.img){const im=document.createElement('img');im.className='q-img';im.src=q.img;im.alt='';im.addEventListener('click',()=>openImgOv(q.img));row.appendChild(im);}
    row.appendChild(acts);list.appendChild(row);
  });
}

/* ══════ 모달 ══════ */
function openAdd(){
  editId=null;imgData=null;imgIsDrawn=false;
  document.getElementById('modal-title').textContent='문제 추가';
  document.getElementById('f-cat').value='';document.getElementById('f-q').value='';
  document.getElementById('f-a').value='';document.getElementById('f-img').value='';
  showZone(true);renderChips();
  document.getElementById('modal').classList.add('open');
  setTimeout(()=>document.getElementById('f-cat').focus(),80);
}
function openEdit(id){
  const q=qs.find(x=>x.id===id);if(!q)return;
  editId=id;imgData=q.img||null;imgIsDrawn=q.imgIsDrawn||false;
  document.getElementById('modal-title').textContent='문제 편집';
  document.getElementById('f-cat').value=q.cat;document.getElementById('f-q').value=q.q;
  document.getElementById('f-a').value=q.a;document.getElementById('f-img').value='';
  if(q.img){document.getElementById('prev-img').src=q.img;showZone(false);}else showZone(true);
  renderChips();document.getElementById('modal').classList.add('open');
}
function closeModal(){document.getElementById('modal').classList.remove('open');}
function showZone(show){
  document.getElementById('img-input-area').style.display=show?'':'none';
  document.getElementById('prev-wrap').style.display=show?'none':'';
}
function renderChips(){
  const wrap=document.getElementById('chips');wrap.innerHTML='';
  [...new Set(qs.map(q=>q.cat))].filter(Boolean).forEach(c=>{
    const ch=document.createElement('span');ch.className='chip';ch.textContent=c;
    ch.addEventListener('click',()=>{document.getElementById('f-cat').value=c;});
    wrap.appendChild(ch);
  });
}
function saveQ(){
  const cat=document.getElementById('f-cat').value.trim();
  const q=document.getElementById('f-q').value.trim();
  const a=document.getElementById('f-a').value.trim();
  if(!cat||!a){alert('카테고리와 정답은 필수입니다.');return;}
  if(editId){const i=qs.findIndex(x=>x.id===editId);if(i>=0)qs[i]={...qs[i],cat,q,a,img:imgData,imgIsDrawn};}
  else qs.push({id:uid(),cat,q,a,img:imgData||null,imgIsDrawn,st:'pending'});
  save();closeModal();renderList();
}
function delQ(id){if(!confirm('정말 삭제할까요?'))return;qs=qs.filter(x=>x.id!==id);save();renderList();}
document.getElementById('btn-cancel').addEventListener('click',closeModal);
document.getElementById('btn-save').addEventListener('click',saveQ);

/* ══════ 이미지 업로드 ══════ */
(function(){
  const zone=document.getElementById('img-zone'),fi=document.getElementById('f-img');
  fi.addEventListener('change',()=>{if(fi.files&&fi.files[0])readFile(fi.files[0]);});
  zone.addEventListener('dragover',e=>{e.preventDefault();zone.classList.add('over');});
  zone.addEventListener('dragleave',()=>zone.classList.remove('over'));
  zone.addEventListener('drop',e=>{e.preventDefault();zone.classList.remove('over');const f=e.dataTransfer.files[0];if(f&&f.type.startsWith('image/'))readFile(f);});
  document.addEventListener('paste',e=>{
    if(!document.getElementById('modal').classList.contains('open'))return;
    if(imgData)return;
    const items=e.clipboardData&&e.clipboardData.items;if(!items)return;
    for(let i=0;i<items.length;i++){if(items[i].type.startsWith('image/')){e.preventDefault();readFile(items[i].getAsFile());return;}}
  });
  document.getElementById('prev-rm').addEventListener('click',()=>{
    imgData=null;imgIsDrawn=false;
    document.getElementById('prev-img').src='';fi.value='';showZone(true);
  });
  document.getElementById('prev-edit').addEventListener('click',()=>{
    if(imgIsDrawn){
      // 그림이면 그림창 열어서 편집 (현재 그림 복원)
      openDrawForEdit();
    } else {
      // 일반 이미지면 크롭 창
      openCropModal(imgData);
    }
  });
})();
function readFile(f){const r=new FileReader();r.onload=e=>showPreview(e.target.result,false);r.readAsDataURL(f);}
function showPreview(src,isDrawn=false){imgData=src;imgIsDrawn=isDrawn;document.getElementById('prev-img').src=src;showZone(false);}

/* ══════════════════════════════════════
   그리기 모달
══════════════════════════════════════ */
(function(){
  const SWATCHES=['#000000','#ffffff','#ef4444','#f97316','#eab308','#22c55e','#3b82f6','#8b5cf6','#ec4899','#6b7280'];
  const LASSO_SW=['#000000','#ef4444','#f97316','#eab308','#22c55e','#3b82f6','#8b5cf6','#ec4899'];

  const cv   = document.getElementById('draw-canvas');
  const ctx  = cv.getContext('2d');
  const lcv  = document.getElementById('lasso-cv');
  const lctx = lcv.getContext('2d');
  const cwrap= document.getElementById('cwrap');

  /* 상태 */
  let userTool='pen', effTool='pen';
  let bsize=11, color='#000000';  // 기본 펜 사이즈 11
  let drawing=false, pts=[];
  let undoStack=[], redoStack=[];
  let sPenBtn=false;

  /* 올가미 상태 */
  let lPath=[];
  let lActive=false;
  let lSnap=null;        // 선택 직전 원본 (cancelLasso 복원용)
  let lBaseSnap=null;    // 선택 영역이 흰색으로 지워진 배경 (이동/리사이즈 기반)
  let lBounds=null;      // {x,y,w,h} 현재 표시 위치/크기
  let lOrigW=0, lOrigH=0;
  let lTmpCv=null;       // 원본 픽셀 캔버스
  let lScale=1.0;
  let lColor=null;
  let lAnimRaf=null;
  let lDash=0;
  let lDragMode=null;
  let lDragStart=null;
  let lDragBounds0=null;
  let lDragScale0=1;

  /* ── 초기화 ── */
  function initCv(w,h){cv.width=w;cv.height=h;fillW();undoStack=[];redoStack=[];saveState();}
  function fillW(){ctx.fillStyle='#fff';ctx.fillRect(0,0,cv.width,cv.height);}
  function saveState(){
    undoStack.push(ctx.getImageData(0,0,cv.width,cv.height));
    if(undoStack.length>60)undoStack.shift();
    redoStack=[];syncUR();
  }
  function syncUR(){
    document.getElementById('btn-undo').disabled=undoStack.length<=1;
    document.getElementById('btn-redo').disabled=redoStack.length===0;
  }

  /* ── lasso canvas 크기/위치 동기 ── */
  function syncLcv(){
    const cr=cv.getBoundingClientRect();
    const wr=cwrap.getBoundingClientRect();
    lcv.width=Math.round(cr.width);
    lcv.height=Math.round(cr.height);
    lcv.style.width=cr.width+'px';
    lcv.style.height=cr.height+'px';
    lcv.style.left=(cr.left-wr.left)+'px';
    lcv.style.top=(cr.top-wr.top)+'px';
  }

  /* ── 색상 팔레트 ── */
  const swWrap=document.getElementById('swatches');
  SWATCHES.forEach(c=>{
    const sw=document.createElement('div');sw.className='sw'+(c===color?' sel':'');
    sw.style.background=c;if(c==='#ffffff')sw.style.border='2px solid #555';
    sw.addEventListener('click',()=>{
      color=c;document.getElementById('custom-color').value=c;
      setUT('pen');document.querySelectorAll('.sw').forEach(s=>s.classList.remove('sel'));sw.classList.add('sel');
    });
    swWrap.appendChild(sw);
  });
  document.getElementById('custom-color').addEventListener('input',e=>{
    color=e.target.value;document.querySelectorAll('.sw').forEach(s=>s.classList.remove('sel'));setUT('pen');
  });

  /* ── 올가미 색상 팔레트 ── */
  const lswWrap=document.getElementById('lasso-swatches');
  LASSO_SW.forEach(c=>{
    const sw=document.createElement('div');sw.className='lp-sw';
    sw.style.background=c;if(c==='#ffffff')sw.style.border='2px solid #555';
    sw.addEventListener('click',()=>{
      lColor=c;document.getElementById('lasso-color').value=c;
      document.querySelectorAll('.lp-sw').forEach(s=>s.classList.remove('sel'));sw.classList.add('sel');
      renderLassoPreview();
    });
    lswWrap.appendChild(sw);
  });
  document.getElementById('lasso-color').addEventListener('input',e=>{
    lColor=e.target.value;document.querySelectorAll('.lp-sw').forEach(s=>s.classList.remove('sel'));
    renderLassoPreview();
  });

  /* ── 굵기 ── */
  const bsR=document.getElementById('bsize'),bLbl=document.getElementById('blbl');
  bsR.value=11; bLbl.textContent=11;  // 기본값 11 반영
  bsR.addEventListener('input',()=>{bsize=+bsR.value;bLbl.textContent=bsize;});

  /* ── 툴 전환 ── */
  function setUT(t){userTool=t;if(!sPenBtn)applyET(t);}
  function applyET(t){
    effTool=t;
    document.getElementById('tool-pen').classList.toggle('on',t==='pen');
    document.getElementById('tool-pen').classList.remove('era-on');
    document.getElementById('tool-eraser').classList.toggle('on',t==='eraser'&&!sPenBtn);
    document.getElementById('tool-eraser').classList.toggle('era-on',t==='eraser'&&sPenBtn);
    document.getElementById('tool-lasso').classList.toggle('on',t==='lasso');
    cv.style.cursor=t==='lasso'?'crosshair':t==='eraser'?'cell':'crosshair';
    const dot=document.getElementById('spen-dot'),lbl=document.getElementById('spen-lbl');
    if(sPenBtn){dot.classList.add('era');lbl.textContent='S펜 버튼 → 지우개';}
    else{dot.classList.remove('era');lbl.textContent='S펜 대기 중';}
  }
  document.getElementById('tool-pen').addEventListener('click',()=>{cancelLasso();setUT('pen');});
  document.getElementById('tool-eraser').addEventListener('click',()=>{cancelLasso();setUT('eraser');});
  document.getElementById('tool-lasso').addEventListener('click',()=>{cancelLasso();setUT('lasso');});

  /* ── 좌표 변환 ── */
  function getPos(clientX,clientY){
    const r=cv.getBoundingClientRect();
    return{x:(clientX-r.left)*(cv.width/r.width),y:(clientY-r.top)*(cv.height/r.height)};
  }
  function isStylus(e){return e.pointerType==='pen'||e.pointerType==='mouse';}

  /* ── S펜 버튼 감지 ── */
  function spenBtn(e){return !!(e.buttons&0b100110);}

  /* ── Bezier 그리기 ── */
  function flushPts(){
    if(pts.length<2)return;
    ctx.beginPath();
    ctx.strokeStyle=effTool==='eraser'?'#fff':color;
    ctx.lineWidth=effTool==='eraser'?bsize*2.5:bsize;
    ctx.lineCap='round';ctx.lineJoin='round';
    ctx.moveTo(pts[0].x,pts[0].y);
    if(pts.length===2){ctx.lineTo(pts[1].x,pts[1].y);}
    else{
      for(let i=1;i<pts.length-1;i++){
        const mx=(pts[i].x+pts[i+1].x)/2,my=(pts[i].y+pts[i+1].y)/2;
        ctx.quadraticCurveTo(pts[i].x,pts[i].y,mx,my);
      }
      ctx.lineTo(pts[pts.length-1].x,pts[pts.length-1].y);
    }
    ctx.stroke();
  }

  /* ════════════════════════════════════
     올가미 로직
  ════════════════════════════════════ */

  /* canvas 좌표 → lasso overlay 픽셀 좌표 */
  function cv2lc(p){
    const r=cv.getBoundingClientRect();
    return{x:p.x*(r.width/cv.width), y:p.y*(r.height/cv.height)};
  }

  /* lBounds를 overlay canvas 좌표로 */
  function boundsOnLcv(){
    if(!lBounds)return null;
    const r=cv.getBoundingClientRect();
    const sx=r.width/cv.width, sy=r.height/cv.height;
    return{x:lBounds.x*sx, y:lBounds.y*sy, w:lBounds.w*sx, h:lBounds.h*sy};
  }

  /* 선택 확정 후 점선 사각형 그리기 */
  function drawLassoDash(){
    lctx.clearRect(0,0,lcv.width,lcv.height);
    if(!lActive||!lBounds)return;
    const b=boundsOnLcv();
    lctx.save();
    lctx.fillStyle='rgba(79,142,247,0.08)';
    lctx.fillRect(b.x,b.y,b.w,b.h);
    lctx.setLineDash([7,4]);
    lctx.lineDashOffset=-lDash;
    lctx.strokeStyle='#4f8ef7';
    lctx.lineWidth=2;
    lctx.strokeRect(b.x,b.y,b.w,b.h);
    lctx.setLineDash([]);
    /* 모서리 핸들 */
    lctx.fillStyle='#fff';lctx.strokeStyle='#4f8ef7';lctx.lineWidth=1.5;
    const hw=6;
    [[b.x,b.y],[b.x+b.w,b.y],[b.x,b.y+b.h],[b.x+b.w,b.y+b.h]].forEach(([hx,hy])=>{
      lctx.beginPath();lctx.arc(hx,hy,hw,0,Math.PI*2);lctx.fill();lctx.stroke();
    });
    lctx.restore();
  }

  /* 드로잉 중 경로 표시 */
  function drawLassoPath(){
    lctx.clearRect(0,0,lcv.width,lcv.height);
    if(lPath.length<2)return;
    lctx.save();
    lctx.beginPath();
    const p0=cv2lc(lPath[0]);lctx.moveTo(p0.x,p0.y);
    lPath.forEach(p=>{const lp=cv2lc(p);lctx.lineTo(lp.x,lp.y);});
    lctx.setLineDash([6,4]);lctx.strokeStyle='#4f8ef7';lctx.lineWidth=1.5;lctx.stroke();
    lctx.setLineDash([]);lctx.restore();
  }

  function animLasso(){lDash=(lDash+0.5)%22;drawLassoDash();lAnimRaf=requestAnimationFrame(animLasso);}

  /* 선택 완료 */
  function finalizeLasso(){
    lPath.push({...lPath[0]});
    const xs=lPath.map(p=>p.x),ys=lPath.map(p=>p.y);
    const x1=Math.max(0,Math.floor(Math.min(...xs)));
    const y1=Math.max(0,Math.floor(Math.min(...ys)));
    const x2=Math.min(cv.width,Math.ceil(Math.max(...xs)));
    const y2=Math.min(cv.height,Math.ceil(Math.max(...ys)));
    if(x2-x1<4||y2-y1<4){cancelLasso();return;}
    lOrigW=x2-x1;lOrigH=y2-y1;
    lBounds={x:x1,y:y1,w:lOrigW,h:lOrigH};
    // 원본 그림 픽셀 저장
    lTmpCv=document.createElement('canvas');
    lTmpCv.width=lOrigW;lTmpCv.height=lOrigH;
    lTmpCv.getContext('2d').putImageData(ctx.getImageData(x1,y1,lOrigW,lOrigH),0,0);
    // 배경 스냅샷: 선택 영역을 흰색으로 지운 상태
    const bgSnap=ctx.getImageData(0,0,cv.width,cv.height);
    const bgTmp=document.createElement('canvas');bgTmp.width=cv.width;bgTmp.height=cv.height;
    const bc=bgTmp.getContext('2d');
    bc.putImageData(bgSnap,0,0);
    bc.fillStyle='#fff';bc.fillRect(x1,y1,lOrigW,lOrigH);
    lBaseSnap=bc.getImageData(0,0,cv.width,cv.height);
    lSnap=bgSnap; // cancelLasso 복원용
    lScale=1.0;lColor=null;lActive=true;
    syncLcv();
    if(lAnimRaf)cancelAnimationFrame(lAnimRaf);
    lDash=0;animLasso();
    document.getElementById('lasso-panel').classList.add('show');
  }

  /* 미리보기 렌더 */
  function renderLassoPreview(){
    if(!lBaseSnap||!lBounds||!lTmpCv)return;
    // lBaseSnap = 선택 영역이 흰색으로 지워진 배경
    ctx.putImageData(lBaseSnap,0,0);
    const{x,y,w,h}=lBounds;
    const out=document.createElement('canvas');out.width=lOrigW;out.height=lOrigH;
    const oc=out.getContext('2d');oc.drawImage(lTmpCv,0,0);
    if(lColor){
      const rr=parseInt(lColor.slice(1,3),16),gg=parseInt(lColor.slice(3,5),16),bb=parseInt(lColor.slice(5,7),16);
      const id=oc.getImageData(0,0,lOrigW,lOrigH);
      for(let i=0;i<id.data.length;i+=4){
        if(id.data[i]<240||id.data[i+1]<240||id.data[i+2]<240){id.data[i]=rr;id.data[i+1]=gg;id.data[i+2]=bb;}
      }
      oc.putImageData(id,0,0);
    }
    ctx.drawImage(out,x,y,w,h);
  }

  /* 점 히트 테스트: 테두리 근처=resize, 내부=move */
  const BHIT=16;
  function lassoHitTest(p){
    if(!lBounds)return null;
    const{x,y,w,h}=lBounds;
    const nearL=Math.abs(p.x-x)<BHIT&&p.y>=y-BHIT&&p.y<=y+h+BHIT;
    const nearR=Math.abs(p.x-(x+w))<BHIT&&p.y>=y-BHIT&&p.y<=y+h+BHIT;
    const nearT=Math.abs(p.y-y)<BHIT&&p.x>=x-BHIT&&p.x<=x+w+BHIT;
    const nearB=Math.abs(p.y-(y+h))<BHIT&&p.x>=x-BHIT&&p.x<=x+w+BHIT;
    if(nearL||nearR||nearT||nearB)return 'resize';
    if(p.x>=x&&p.x<=x+w&&p.y>=y&&p.y<=y+h)return 'move';
    return null;
  }

  function updateCursor(p){
    if(!lActive){cv.style.cursor='crosshair';return;}
    const h=lassoHitTest(p);
    cv.style.cursor=h==='resize'?'nwse-resize':h==='move'?'move':'crosshair';
  }

  /* 올가미 취소 */
  function cancelLasso(){
    if(lSnap)ctx.putImageData(lSnap,0,0);
    lActive=false;lPath=[];lBounds=null;lOrigW=0;lOrigH=0;
    lSnap=null;lBaseSnap=null;lTmpCv=null;lScale=1.0;lColor=null;
    lDragMode=null;lDragStart=null;lDragBounds0=null;
    if(lAnimRaf){cancelAnimationFrame(lAnimRaf);lAnimRaf=null;}
    lctx.clearRect(0,0,lcv.width,lcv.height);
    document.getElementById('lasso-panel').classList.remove('show');
    cv.style.cursor='crosshair';
  }

  /* 올가미 적용 */
  document.getElementById('lasso-apply').addEventListener('click',()=>{
    renderLassoPreview();saveState();
    lActive=false;lPath=[];lBounds=null;lOrigW=0;lOrigH=0;
    lSnap=null;lBaseSnap=null;lTmpCv=null;lScale=1.0;lColor=null;lDragMode=null;
    if(lAnimRaf){cancelAnimationFrame(lAnimRaf);lAnimRaf=null;}
    lctx.clearRect(0,0,lcv.width,lcv.height);
    document.getElementById('lasso-panel').classList.remove('show');
    cv.style.cursor='crosshair';
  });
  document.getElementById('lasso-cancel').addEventListener('click',cancelLasso);
  document.getElementById('lasso-delete').addEventListener('click',()=>{
    // 선택 영역을 흰색으로 지우고 확정
    if(!lBaseSnap||!lBounds)return;
    ctx.putImageData(lBaseSnap,0,0); // 배경 복원 (선택 영역 이미 없음)
    saveState();
    lActive=false;lPath=[];lBounds=null;lOrigW=0;lOrigH=0;
    lSnap=null;lBaseSnap=null;lTmpCv=null;lScale=1.0;lColor=null;lDragMode=null;
    if(lAnimRaf){cancelAnimationFrame(lAnimRaf);lAnimRaf=null;}
    lctx.clearRect(0,0,lcv.width,lcv.height);
    document.getElementById('lasso-panel').classList.remove('show');
    cv.style.cursor='crosshair';
  });

  /* ════ Pointer 이벤트 ════ */
  cv.addEventListener('pointerdown',e=>{
    if(!isStylus(e)||!e.isPrimary)return;
    e.preventDefault();
    cv.setPointerCapture(e.pointerId);
    const held=spenBtn(e);
    if(held!==sPenBtn){sPenBtn=held;applyET(sPenBtn?'eraser':userTool);}
    const p=getPos(e.clientX,e.clientY);

    if(effTool==='lasso'){
      if(lActive){
        const hit=lassoHitTest(p);
        if(hit){
          lDragMode=hit;lDragStart=p;
          lDragBounds0={...lBounds};lDragScale0=lScale;
        } else {
          // 범위 밖 클릭 → 올가미 해제
          cancelLasso();
        }
        return;
      }
      lPath=[];lctx.clearRect(0,0,lcv.width,lcv.height);
      lPath.push(p);drawing=true;
      return;
    }

    drawing=true;pts=[];pts.push(p);
    ctx.beginPath();ctx.arc(p.x,p.y,(effTool==='eraser'?bsize*2.5:bsize)/2,0,Math.PI*2);
    ctx.fillStyle=effTool==='eraser'?'#fff':color;ctx.fill();
  },{passive:false});

  cv.addEventListener('pointermove',e=>{
    if(!isStylus(e))return;
    e.preventDefault();
    const held=spenBtn(e);
    if(held!==sPenBtn){sPenBtn=held;applyET(sPenBtn?'eraser':userTool);}
    const p=getPos(e.clientX,e.clientY);

    if(effTool==='lasso'){
      if(lActive&&lDragMode&&lDragBounds0){
        const dx=p.x-lDragStart.x, dy=p.y-lDragStart.y;
        if(lDragMode==='move'){
          lBounds={x:lDragBounds0.x+dx, y:lDragBounds0.y+dy, w:lDragBounds0.w, h:lDragBounds0.h};
          renderLassoPreview();drawLassoDash();
        } else {
          /* resize: 중심 고정, 드래그 거리 비율로 스케일 */
          const cx0=lDragBounds0.x+lDragBounds0.w/2, cy0=lDragBounds0.y+lDragBounds0.h/2;
          const d0=Math.hypot(lDragStart.x-cx0, lDragStart.y-cy0);
          const d1=Math.hypot(p.x-cx0, p.y-cy0);
          if(d0>3){
            const ns=Math.max(0.05,Math.min(8,lDragScale0*(d1/d0)));
            lScale=ns;
            const nw=Math.round(lOrigW*ns), nh=Math.round(lOrigH*ns);
            lBounds={x:Math.round(cx0-nw/2), y:Math.round(cy0-nh/2), w:nw, h:nh};
            renderLassoPreview();drawLassoDash();
          }
        }
        return;
      }
      if(lActive)updateCursor(p);
      if(drawing){lPath.push(p);drawLassoPath();}
      return;
    }

    if(!drawing)return;
    pts.push(p);if(pts.length>4)pts.shift();flushPts();
  },{passive:false});

  cv.addEventListener('pointerup',e=>{
    const held=spenBtn(e);
    if(!held&&sPenBtn){sPenBtn=false;applyET(userTool);}

    if(effTool==='lasso'){
      if(lDragMode){
        lDragMode=null;lDragStart=null;lDragBounds0=null;
        return;
      }
      if(drawing){
        drawing=false;
        if(lPath.length>3)finalizeLasso();
        else{lPath=[];lctx.clearRect(0,0,lcv.width,lcv.height);}
      }
      return;
    }
    if(!drawing)return;
    drawing=false;pts=[];saveState();
  },{passive:false});

  cv.addEventListener('pointercancel',()=>{
    drawing=false;pts=[];lDragMode=null;
    if(sPenBtn){sPenBtn=false;applyET(userTool);}
  });

  /* ════ 실행취소/다시하기 ════ */
  document.getElementById('btn-undo').addEventListener('click',()=>{
    if(undoStack.length<=1)return;
    redoStack.push(undoStack.pop());
    const s=undoStack[undoStack.length-1];cv.width=s.width;cv.height=s.height;ctx.putImageData(s,0,0);syncUR();
  });
  document.getElementById('btn-redo').addEventListener('click',()=>{
    if(!redoStack.length)return;
    const s=redoStack.pop();undoStack.push(s);cv.width=s.width;cv.height=s.height;ctx.putImageData(s,0,0);syncUR();
  });
  document.addEventListener('keydown',e=>{
    if(!document.getElementById('draw-ov').classList.contains('open'))return;
    if((e.ctrlKey||e.metaKey)&&e.key==='z'){e.preventDefault();document.getElementById('btn-undo').click();}
    if((e.ctrlKey||e.metaKey)&&(e.key==='y'||(e.shiftKey&&e.key==='Z'))){e.preventDefault();document.getElementById('btn-redo').click();}
  });

  /* ════ 전체 지우기 ════ */
  document.getElementById('btn-clear').addEventListener('click',()=>{cancelLasso();fillW();saveState();});

  /* ════ 캔버스 크기 ════ */
  const SIZES=[{w:300,h:225},{w:450,h:338},{w:600,h:450},{w:800,h:600},{w:1000,h:750}];
  let szIdx=2;
  function updSzLbl(){
    const s=SIZES[szIdx];document.getElementById('sz-lbl').textContent=s.w+'×'+s.h;
    document.getElementById('btn-sz-dn').disabled=szIdx===0;
    document.getElementById('btn-sz-up').disabled=szIdx===SIZES.length-1;
  }
  function resizeCv(ni){
    const to=SIZES[ni];
    const snap=ctx.getImageData(0,0,cv.width,cv.height);
    const tmp=document.createElement('canvas');tmp.width=cv.width;tmp.height=cv.height;
    tmp.getContext('2d').putImageData(snap,0,0);
    cv.width=to.w;cv.height=to.h;fillW();ctx.drawImage(tmp,0,0,to.w,to.h);
    szIdx=ni;updSzLbl();undoStack=[];redoStack=[];saveState();
    requestAnimationFrame(syncLcv);
  }
  document.getElementById('btn-sz-dn').addEventListener('click',()=>{if(szIdx>0)resizeCv(szIdx-1);});
  document.getElementById('btn-sz-up').addEventListener('click',()=>{if(szIdx<SIZES.length-1)resizeCv(szIdx+1);});

  /* ════ 모달 열기/닫기 ════ */
  function openDrawFresh(){
    // 항상 새 캔버스로 시작
    cancelLasso();
    initCv(600,450);
    szIdx=2;
    bsize=11;bsR.value=11;bLbl.textContent=11;
    setUT('pen');syncUR();updSzLbl();
    document.getElementById('draw-ov').classList.add('open');
    requestAnimationFrame(syncLcv);
  }

  function openDrawForEdit(){
    // 기존 그림(base64)을 캔버스에 복원해서 편집
    cancelLasso();
    const img=new Image();
    img.onload=()=>{
      initCv(img.naturalWidth||600, img.naturalHeight||450);
      ctx.drawImage(img,0,0);
      undoStack=[];saveState();
      szIdx=SIZES.reduce((best,s,i)=>Math.abs(s.w-img.naturalWidth)<Math.abs(SIZES[best].w-img.naturalWidth)?i:best,2);
      bsize=11;bsR.value=11;bLbl.textContent=11;
      setUT('pen');syncUR();updSzLbl();
      document.getElementById('draw-ov').classList.add('open');
      requestAnimationFrame(syncLcv);
    };
    img.src=imgData;
  }
  // 외부에서 호출 가능하게 전역 등록
  window.openDrawForEdit=openDrawForEdit;

  document.getElementById('btn-draw').addEventListener('click',openDrawFresh);

  document.getElementById('btn-draw-cancel').addEventListener('click',()=>{
    cancelLasso();
    initCv(600,450); // 취소해도 리셋
    document.getElementById('draw-ov').classList.remove('open');
  });
  document.getElementById('btn-draw-ok').addEventListener('click',()=>{
    const d=ctx.getImageData(0,0,cv.width,cv.height).data;
    let blank=true;
    for(let i=0;i<d.length;i+=4){if(d[i]<250||d[i+1]<250||d[i+2]<250){blank=false;break;}}
    if(blank){alert('그림을 먼저 그려주세요.');return;}
    const src=cv.toDataURL('image/png');
    showPreview(src,true);  // isDrawn=true
    cancelLasso();
    initCv(600,450); // 완료 후 리셋
    document.getElementById('draw-ov').classList.remove('open');
  });
})();

/* ══════ 크롭 모달 ══════ */
(function(){
  let cropImg=null, dispW=0, dispH=0, natW=0, natH=0;
  let box={x:20,y:20,w:0,h:0};
  let dragMode=null; // 'move' | 'tl'|'tr'|'bl'|'br'
  let dragStart=null, boxStart=null;

  const modal=document.getElementById('crop-modal');
  const wrap=document.getElementById('crop-wrap');
  const img=document.getElementById('crop-src-img');
  const cropBox=document.getElementById('crop-box');

  function clamp(v,min,max){return Math.max(min,Math.min(max,v));}

  function setBox(b){
    box.x=clamp(b.x,0,dispW-20);
    box.y=clamp(b.y,0,dispH-20);
    box.w=clamp(b.w,20,dispW-box.x);
    box.h=clamp(b.h,20,dispH-box.y);
    renderBox();
  }

  function renderBox(){
    cropBox.style.left=box.x+'px';
    cropBox.style.top=box.y+'px';
    cropBox.style.width=box.w+'px';
    cropBox.style.height=box.h+'px';
    // 핸들 위치
    posHandle('ch-tl',box.x-5,box.y-5);
    posHandle('ch-tr',box.x+box.w-7,box.y-5);
    posHandle('ch-bl',box.x-5,box.y+box.h-7);
    posHandle('ch-br',box.x+box.w-7,box.y+box.h-7);
  }
  function posHandle(id,x,y){
    const h=document.getElementById(id);
    h.style.position='absolute';h.style.left=x+'px';h.style.top=y+'px';
  }

  function getWrapPos(e){
    const r=wrap.getBoundingClientRect();
    const src=e.touches?e.touches[0]:e;
    return{x:src.clientX-r.left, y:src.clientY-r.top};
  }

  function hitTest(p){
    const hw=10;
    if(Math.abs(p.x-box.x)<hw&&Math.abs(p.y-box.y)<hw)return 'tl';
    if(Math.abs(p.x-(box.x+box.w))<hw&&Math.abs(p.y-box.y)<hw)return 'tr';
    if(Math.abs(p.x-box.x)<hw&&Math.abs(p.y-(box.y+box.h))<hw)return 'bl';
    if(Math.abs(p.x-(box.x+box.w))<hw&&Math.abs(p.y-(box.y+box.h))<hw)return 'br';
    if(p.x>box.x&&p.x<box.x+box.w&&p.y>box.y&&p.y<box.y+box.h)return 'move';
    return null;
  }

  wrap.addEventListener('pointerdown',e=>{
    e.preventDefault();wrap.setPointerCapture(e.pointerId);
    const p=getWrapPos(e);dragMode=hitTest(p);
    dragStart=p;boxStart={...box};
  },{passive:false});
  wrap.addEventListener('pointermove',e=>{
    if(!dragMode)return;e.preventDefault();
    const p=getWrapPos(e),dx=p.x-dragStart.x,dy=p.y-dragStart.y;
    const b={...boxStart};
    if(dragMode==='move'){b.x+=dx;b.y+=dy;}
    else if(dragMode==='tl'){b.x+=dx;b.y+=dy;b.w-=dx;b.h-=dy;}
    else if(dragMode==='tr'){b.y+=dy;b.w+=dx;b.h-=dy;}
    else if(dragMode==='bl'){b.x+=dx;b.w-=dx;b.h+=dy;}
    else if(dragMode==='br'){b.w+=dx;b.h+=dy;}
    setBox(b);
  },{passive:false});
  wrap.addEventListener('pointerup',()=>dragMode=null);

  window.openCropModal=function(src){
    cropImg=new Image();
    cropImg.onload=()=>{
      natW=cropImg.naturalWidth;natH=cropImg.naturalHeight;
      img.src=src;
      // 크기 확정 후 box 초기화
      requestAnimationFrame(()=>{
        dispW=img.offsetWidth;dispH=img.offsetHeight;
        box={x:0,y:0,w:dispW,h:dispH};
        renderBox();
        modal.classList.add('open');
      });
    };
    cropImg.src=src;
  };

  document.getElementById('btn-crop-cancel').addEventListener('click',()=>{
    modal.classList.remove('open');
  });
  document.getElementById('btn-crop-ok').addEventListener('click',()=>{
    if(!cropImg)return;
    dispW=img.offsetWidth;dispH=img.offsetHeight;
    const sx=natW/dispW, sy=natH/dispH;
    const nx=Math.round(box.x*sx), ny=Math.round(box.y*sy);
    const nw=Math.round(box.w*sx), nh=Math.round(box.h*sy);
    const tmp=document.createElement('canvas');
    tmp.width=Math.max(1,nw);tmp.height=Math.max(1,nh);
    tmp.getContext('2d').drawImage(cropImg,nx,ny,nw,nh,0,0,nw,nh);
    showPreview(tmp.toDataURL('image/png'),false);
    modal.classList.remove('open');
  });
})();

/* ══════ 카테고리 메뉴 ══════ */
let catMenuKey=null;
function openCatMenu(key){
  catMenuKey=key;
  document.getElementById('cat-menu-name').textContent=key;
  document.getElementById('cat-menu').classList.add('open');
}
document.getElementById('cat-menu-close').addEventListener('click',()=>{
  document.getElementById('cat-menu').classList.remove('open');
});
document.getElementById('cat-menu-rename').addEventListener('click',()=>{
  const newName=prompt('새 카테고리 이름을 입력하세요:',catMenuKey);
  if(!newName||!newName.trim()||newName.trim()===catMenuKey){
    document.getElementById('cat-menu').classList.remove('open');return;
  }
  const n=newName.trim();
  qs.forEach(q=>{if(q.cat===catMenuKey)q.cat=n;});
  save();
  document.getElementById('cat-menu').classList.remove('open');
  renderHome();
});
document.getElementById('cat-menu-delete').addEventListener('click',()=>{
  const count=qs.filter(q=>q.cat===catMenuKey).length;
  if(!confirm(`"${catMenuKey}" 카테고리의 문제 ${count}개를 모두 삭제할까요?`)){return;}
  qs=qs.filter(q=>q.cat!==catMenuKey);
  save();
  document.getElementById('cat-menu').classList.remove('open');
  renderHome();
});

/* ══════ 퀴즈 ══════ */
function startQuiz(key){
  qCat=key;let pool;
  if(key==='__ALL__')pool=[...qs];
  else if(key.startsWith('__st__'))pool=qs.filter(q=>q.st===key.replace('__st__',''));
  else pool=qs.filter(q=>q.cat===key);
  if(!pool.length){alert('이 카테고리에 문제가 없습니다.');return;}
  queue=[...pool];if(qOrd==='rnd')shuffle(queue);qIdx=0;
  const qt=document.getElementById('tab-quiz');qt.style.pointerEvents='';qt.style.opacity='';
  showScreen('quiz');drawQ();drawDots();
}
function setOrder(ord){
  qOrd=ord;
  document.getElementById('ord-seq').classList.toggle('active',ord==='seq');
  document.getElementById('ord-rnd').classList.toggle('active',ord==='rnd');
  if(!queue.length)return;
  const ids=queue.map(q=>q.id);
  queue=ord==='rnd'?(shuffle(queue.slice(0)),queue):qs.filter(q=>ids.includes(q.id));
  qIdx=0;drawQ();drawDots();
}
function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}
function drawQ(){
  if(qIdx>=queue.length){showResult();return;}
  const q=queue[qIdx],total=queue.length;
  document.getElementById('prog-lbl').textContent=`${qIdx+1} / ${total}`;
  document.getElementById('pfill').style.width=`${(qIdx/total)*100}%`;
  document.getElementById('prog-cat').textContent=qCat==='__ALL__'?'전체':qCat.startsWith('__st__')?'':qCat;
  const area=document.getElementById('quiz-area');area.innerHTML='';
  const card=document.createElement('div');card.className='qcard';
  const num=document.createElement('div');num.className='qnum';num.textContent=`Q${qIdx+1} · ${q.cat}`;
  const txt=document.createElement('div');txt.className='qtxt';txt.textContent=q.q;
  card.append(num,txt);
  if(q.img){const im=document.createElement('img');im.className='qimg';im.src=q.img;im.alt='';im.addEventListener('click',()=>openImgOv(q.img));card.appendChild(im);}
  area.appendChild(card);
  const row=document.createElement('div');row.className='ans-row';
  const inp=document.createElement('input');
  inp.className='ans-in';inp.type='text';inp.placeholder='정답을 입력하세요…';inp.autocomplete='off';
  const btn=document.createElement('button');btn.className='sub-btn';btn.textContent='제출 ↵';
  const submit=()=>{
    if(inp.disabled)return;const ans=inp.value.trim();if(!ans)return;
    inp.disabled=true;btn.disabled=true;
    const ok=norm(ans)===norm(q.a);
    const orig=qs.find(x=>x.id===q.id);if(orig)orig.st=ok?'correct':'wrong';
    queue[qIdx].st=ok?'correct':'wrong';save();drawDots();
    showFB(ok,q.a,()=>{qIdx++;drawQ();drawDots();});
  };
  inp.addEventListener('keydown',e=>{if(e.key==='Enter')submit();});
  btn.addEventListener('click',submit);
  row.append(inp,btn);area.appendChild(row);
  setTimeout(()=>inp.focus(),80);
}
function drawDots(){
  const nav=document.getElementById('dot-nav');nav.innerHTML='';
  queue.forEach((q,i)=>{
    const d=document.createElement('div');d.className=`dn ${q.st} ${i===qIdx?'cur':''}`;
    d.textContent=q.st==='correct'?'○':q.st==='wrong'?'✕':'?';d.title=q.q;
    d.addEventListener('click',()=>{qIdx=i;drawQ();drawDots();});nav.appendChild(d);
  });
}
function showFB(ok,ans,cb){
  const DUR=ok?2000:5000,CIRC=2*Math.PI*19;
  const box=document.getElementById('fb-box'),circ=document.getElementById('fg-c'),tnum=document.getElementById('fb-tnum');
  box.className='fb-box '+(ok?'ok':'er');
  document.getElementById('fb-icon').textContent=ok?'🎉':'😓';
  document.getElementById('fb-lbl').textContent=ok?'정답!':'오답';
  const ad=document.getElementById('fb-ans');
  if(ok){ad.innerHTML='';}else{ad.innerHTML='정답: <strong></strong>';ad.querySelector('strong').textContent=ans;}
  circ.style.strokeDasharray=CIRC;circ.style.strokeDashoffset=0;tnum.textContent=ok?'2':'5';
  document.getElementById('fb-ov').classList.add('show');
  if(rafId)cancelAnimationFrame(rafId);
  let t0=null;
  const tick=ts=>{if(!t0)t0=ts;const el=ts-t0,fr=Math.min(el/DUR,1);circ.style.strokeDashoffset=CIRC*fr;tnum.textContent=Math.ceil((DUR-el)/1000)||'…';if(fr<1)rafId=requestAnimationFrame(tick);else{document.getElementById('fb-ov').classList.remove('show');cb();}};
  rafId=requestAnimationFrame(tick);
}
function showResult(){
  const c=queue.filter(q=>q.st==='correct').length,w=queue.filter(q=>q.st==='wrong').length,total=queue.length,pct=Math.round(c/total*100);
  const area=document.getElementById('quiz-area');area.innerHTML='';
  const div=document.createElement('div');div.className='result';
  div.innerHTML=`<div class="big">${pct>=80?'🏆':pct>=50?'👍':'💪'}</div><div class="rtit">세션 완료!</div><div class="rsub">${total}문제 중 ${c}문제 정답 (${pct}%)</div>
    <div class="rstats"><div class="rstat"><div class="n" style="color:var(--ok)">${c}</div><div class="l">정답</div></div><div class="rstat"><div class="n" style="color:var(--err)">${w}</div><div class="l">오답</div></div></div>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap"><button class="btn btn-p" id="btn-retry">🔄 다시 풀기</button><button class="btn btn-s" id="btn-home2">🏠 홈으로</button></div>`;
  area.appendChild(div);
  div.querySelector('#btn-retry').addEventListener('click',()=>startQuiz(qCat));
  div.querySelector('#btn-home2').addEventListener('click',goHome);
}
function goHome(){showScreen('home');}
function openImgOv(src){document.getElementById('img-ov-img').src=src;document.getElementById('img-ov').classList.add('open');}
document.getElementById('img-ov').addEventListener('click',()=>document.getElementById('img-ov').classList.remove('open'));
renderHome();
</script>
